# Auto Job Hunter AI - Environment Variables

# Backend / API
API_V1_STR=/api/v1
SECRET_KEY=generate_a_super_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobhunter
DATABASE_URI=postgresql+asyncpg://postgres:postgres@db:5432/jobhunter
# For local dev without docker, use SQLite
# DATABASE_URI=sqlite+aiosqlite:///./jobhunter.db

# Redis / Celery (Optional, for background tasks)
REDIS_URL=redis://redis:6379/0

# AI Provider (OpenAI, Anthropic, or Gemini)
AI_PROVIDER=openai # openai, anthropic, gemini
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key

# Playwright Automation
PLAYWRIGHT_HEADLESS=true
USER_DATA_DIR=./browser_data

# Frontend URLs
FRONTEND_URL=http://localhost:3000
